# Скопируй в .env (или впиши в переменные окружения на хостинге). .env НЕ коммить!

# Реальный ключ LLM — СЕКРЕТ. Только тут / в панели хостинга, никогда в коде и гите.
LLM_API_KEY=sk-замени-меня
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Клиентские токены (через запятую) — их фронт шлёт как "ключ". Защищают прокси от чужих.
# Придумай длинные случайные строки.
CLIENT_TOKENS=придумай-длинный-токен-1

# Разрешённые origin фронта (через запятую). Для GitHub Pages:
ALLOWED_ORIGINS=https://USERNAME.github.io

# Лимит запросов с одного IP в минуту.
RATE_LIMIT_PER_MIN=30
